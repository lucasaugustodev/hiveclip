# Supabase PostgreSQL connection string (Settings > Database > Connection string > URI > Transaction mode)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://xxx.supabase.co

# Supabase anon key - safe for frontend (Settings > API > anon public)
SUPABASE_ANON_KEY=eyJ...

# Supabase service role key - SECRET, never expose (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Vultr API key (for VM provisioning)
VULTR_API_KEY=

# Server port (default: 3100)
PORT=3100
